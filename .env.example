# Cloudflare credentials — required for all components
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# Optional: D1 database ID (for D1MessageHistory)
# Create with: npx wrangler d1 create my-chat-history
# D1_DATABASE_ID=your-d1-uuid

# Optional: Vectorize index name (for VectorizeToolset)
# Create with: npx wrangler vectorize create my-knowledge-base --dimensions 768 --metric cosine
# VECTORIZE_INDEX_NAME=my-knowledge-base
